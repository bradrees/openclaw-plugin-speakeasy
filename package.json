{
  "name": "@bradrees/openclaw-plugin-speakeasy",
  "version": "0.1.0",
  "description": "OpenClaw channel plugin for the Speakeasy external agent API.",
  "type": "module",
  "license": "MIT",
  "author": "Brad Rees",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bradrees/openclaw-plugin-speakeasy.git"
  },
  "homepage": "https://github.com/bradrees/openclaw-plugin-speakeasy#readme",
  "bugs": {
    "url": "https://github.com/bradrees/openclaw-plugin-speakeasy/issues"
  },
  "files": [
    "dist",
    "README.md",
    "openclaw.plugin.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./setup": {
      "types": "./dist/src/setup.d.ts",
      "default": "./dist/src/setup.js"
    },
    "./session-key-api": {
      "types": "./dist/src/session-key-api.d.ts",
      "default": "./dist/src/session-key-api.js"
    },
    "./auth": {
      "types": "./dist/src/auth.d.ts",
      "default": "./dist/src/auth.js"
    },
    "./connect": {
      "types": "./dist/src/connect.d.ts",
      "default": "./dist/src/connect.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node ./scripts/run-vitest.mjs run --config ./vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "tsc -p tsconfig.json"
  },
  "peerDependencies": {
    "openclaw": "^2026.4.14"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "openclaw": "^2026.4.14",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "openclaw": {
    "extensions": [
      "./dist/src/index.js"
    ],
    "setupEntry": "./dist/src/setup.js",
    "channel": {
      "id": "speakeasy",
      "label": "Speakeasy",
      "selectionLabel": "Speakeasy (plugin)",
      "docsPath": "/channels/speakeasy",
      "docsLabel": "speakeasy",
      "blurb": "Connects the Speakeasy agent API as a topic-first OpenClaw channel.",
      "order": 70,
      "quickstartAllowFrom": true,
      "persistedAuthState": {
        "specifier": "./dist/src/auth.js",
        "exportName": "hasAnySpeakeasyAuth"
      },
      "configuredState": {
        "specifier": "./dist/src/auth.js",
        "exportName": "hasAnySpeakeasyConfiguredState"
      }
    },
    "compat": {
      "pluginApi": ">=2026.4.14",
      "minGatewayVersion": "2026.4.14"
    },
    "build": {
      "openclawVersion": "2026.4.14",
      "pluginSdkVersion": "2026.4.14"
    }
  }
}
